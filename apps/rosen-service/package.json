{
  "name": "@rosen-bridge/rosen-service",
  "version": "4.3.6",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosen-bridge/ui.git"
  },
  "license": "MIT",
  "author": "Rosen Team",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "scripts": {
    "get-config": "npx @rosen-bridge/cli download-assets --chain-type public-launch --out config",
    "lint": "biome check --write",
    "lint:check": "biome check",
    "prettify": "biome format --write",
    "prettify:check": "biome format",
    "start": "tsx watch ./src/main.ts",
    "start:prod": "tsx ./src/main.ts",
    "type-check": "tsc --noEmit",
    "typeorm": "NODE_OPTIONS='--import tsx' typeorm",
    "typeorm:generate": "npm run typeorm migration:generate ./src/db/migrations/migration -- -p -d ./src/data-source.ts",
    "typeorm:migrate": "npm run typeorm migration:run -- -d ./src/data-source.ts"
  },
  "dependencies": {
    "@rosen-bridge/abstract-logger": "^4.0.0",
    "@rosen-bridge/abstract-scanner": "^2.0.2",
    "@rosen-bridge/address-codec": "^2.1.0",
    "@rosen-bridge/address-manager": "^0.1.0",
    "@rosen-bridge/bitcoin-observation-extractor": "^8.0.4",
    "@rosen-bridge/bitcoin-runes-observation-extractor": "^3.0.5",
    "@rosen-bridge/bitcoin-scanner": "^1.1.2",
    "@rosen-bridge/callback-logger": "^2.0.0",
    "@rosen-bridge/cardano-observation-extractor": "^3.0.4",
    "@rosen-bridge/cardano-scanner": "^2.1.2",
    "@rosen-bridge/discord-notification": "^1.0.0",
    "@rosen-bridge/ergo-observation-extractor": "^2.0.4",
    "@rosen-bridge/ergo-scanner": "^1.1.2",
    "@rosen-bridge/evm-observation-extractor": "^7.0.4",
    "@rosen-bridge/evm-scanner": "^1.1.2",
    "@rosen-bridge/firo-observation-extractor": "^1.1.2",
    "@rosen-bridge/firo-scanner": "^0.2.2",
    "@rosen-bridge/health-check": "^8.0.0",
    "@rosen-bridge/log-level-check": "^4.0.0",
    "@rosen-bridge/scanner-interfaces": "^1.0.0",
    "@rosen-bridge/scanner-sync-check": "^8.2.0",
    "@rosen-bridge/tokens": "^6.0.2",
    "@rosen-bridge/watcher-data-extractor": "^13.0.9",
    "@rosen-bridge/winston-logger": "^3.1.0",
    "@rosen-clients/rate-limited-axios": "^2.0.1",
    "@rosen-ui/asset-calculator": "^2.3.3",
    "@rosen-ui/constants": "^1.0.0",
    "@rosen-ui/data-source": "^0.2.6",
    "config": "^3.3.12",
    "ethers": "6.16.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/config": "^0.0.41",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=22.18.0",
    "npm": "11.6.2"
  }
}
