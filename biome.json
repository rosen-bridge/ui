{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!**/.next/**/*", "!**/dist/**/*", "!**/out/**/*"]
  },
  "formatter": {
    "enabled": true,
    "lineWidth": 80,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "complexity": {
        "noImportantStyles": "off",
        "noStaticOnlyClass": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "noDescendingSpecificity": "off",
        "noNonNullAssertion": "off",
        "useLiteralEnumMembers": "off"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "useIterableCallbackReturn": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "quoteProperties": "preserve",
      "trailingCommas": "all"
    }
  },
  "css": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "useSortedPackageJson": "on",
        "organizeImports": {
          "level": "on",
          "options": {
            "sortBareImports": true,
            "groups": [
              "**/bootstrap",
              ":BLANK_LINE:",

              ":NODE:",
              ":BLANK_LINE:",

              ["react", "react/**"],
              ["next", "next/**"],
              ":BLANK_LINE:",

              [":PACKAGE:", "!@rosen-*/**"],
              ":BLANK_LINE:",

              "@rosen*/**",
              ":BLANK_LINE:",

              ":ALIAS:",
              ":BLANK_LINE:",

              [":PATH:", "!:STYLE:"],
              ":BLANK_LINE:",

              ":STYLE:",
              ":BLANK_LINE:"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": ["apps/guard/**/*", "apps/rosen/**/*", "apps/watcher/**/*"],
      "linter": {
        "domains": {
          "next": "recommended",
          "react": "recommended"
        }
      }
    },
    {
      "includes": ["packages/ui-kit/**/*"],
      "linter": {
        "domains": {
          "react": "recommended"
        },
        "rules": {
          "suspicious": {
            "noEmptyInterface": "off"
          },
          "complexity": {
            "noBannedTypes": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/rosen-service2/**/*",
        "packages/asset-aggregator/**/*",
        "packages/asset-calculator/**/*",
        "packages/asset-data-adapter/**/*"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "useLiteralKeys": "off",
            "useOptionalChain": "off"
          },
          "suspicious": {
            "noDoubleEquals": "off"
          }
        }
      }
    }
  ]
}
