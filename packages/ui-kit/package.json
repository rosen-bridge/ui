{
  "name": "@rosen-bridge/ui-kit",
  "version": "5.4.0",
  "private": true,
  "description": "ui kit for Rosen projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosen-bridge/ui.git"
  },
  "license": "MIT",
  "author": "Rosen Team",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./style.css": "./dist/style.css",
    "./dist/components/common/smartSearch/server": "./dist/components/common/smartSearch/server.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "eslint --fix . && npm run prettify",
    "lint:check": "eslint . && npm run prettify:check",
    "prettify": "prettier --write . --ignore-path ../../.gitignore",
    "prettify:check": "prettier --check . --ignore-path ../../.gitignore",
    "release": "npm run build && npm publish --access public",
    "test": "NODE_OPTIONS='--import tsx' vitest",
    "type-check": "tsc"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@mui/material": "^7.3.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@rosen-bridge/icons": "^3.6.0",
    "@rosen-ui/constants": "^1.0.0",
    "@rosen-ui/swr-helpers": "^0.2.2",
    "@rosen-ui/utils": "^1.0.3",
    "embla-carousel-react": "^8.5.2",
    "joi": "^17.11.0",
    "qrcode.react": "^4.2.0",
    "react-hook-form": "^7.71.2",
    "react-sticky-box": "^2.0.5"
  },
  "devDependencies": {
    "@rosen-ui/types": "^0.5.0",
    "@tsdown/css": "^0.21.0",
    "autoprefixer": "^10.4.27",
    "sass": "^1.98.0",
    "tsdown": "^0.21.0"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "swr": "^2.4.1"
  },
  "engines": {
    "node": ">=22.18.0",
    "npm": "11.6.2"
  }
}
